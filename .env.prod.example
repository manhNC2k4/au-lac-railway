# copy to .env on the VPS, next to docker-compose.prod.yml. never commit the real file.

POSTGRES_USER=aulac_user
POSTGRES_PASSWORD=change-me
POSTGRES_DB=aulac_db

# lowercase github org/user and repo name, e.g. ghcr.io/acme/aulac-railway-backend
GHCR_OWNER=your-github-owner
GHCR_REPO=aulac-railway
IMAGE_TAG=latest
