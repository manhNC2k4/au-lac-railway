# frontend (Next.js), proxies to the frontend container. copy to
# /etc/nginx/sites-available/app.example.com, symlink into sites-enabled,
# swap app.example.com for the real subdomain, then run:
#   certbot --nginx -d app.example.com
# certbot rewrites this file in place to add the SSL block + HTTP->HTTPS redirect.

server {
    listen 80;
    listen [::]:80;
    server_name app.example.com;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
