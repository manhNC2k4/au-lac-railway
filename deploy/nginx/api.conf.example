# backend (FastAPI/uvicorn), proxies to the backend container. copy to
# /etc/nginx/sites-available/api.example.com, symlink into sites-enabled,
# swap api.example.com for the real subdomain, then run:
#   certbot --nginx -d api.example.com
# certbot rewrites this file in place to add the SSL block + HTTP->HTTPS redirect.

server {
    listen 80;
    listen [::]:80;
    server_name api.example.com;

    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
